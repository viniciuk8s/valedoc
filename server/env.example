# .env — Variáveis de ambiente ValeDoc
# Renomeie este arquivo para ".env" e preencha com seus dados reais
# NUNCA suba o arquivo .env para o Git!

# ── Banco de dados ────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=valedoc

# ── Servidor ──────────────────────────────────
PORT=3000

# ── CORS (origem do front-end em produção) ────
# Deixe * apenas em desenvolvimento
FRONT_ORIGIN=*
